{% extends 'base.html.twig' %}

{% block title %}{{ 'user'|trans|capitalize }}{% endblock %}

{% block main %}
    <h1>{{ 'user'|trans|capitalize }}</h1>
    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ user.id }}</td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td>{{ user.email }}</td>
                </tr>
                <tr>
                    <th>Roles</th>
                    <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
                </tr>                
                <tr>
                    <th>{{ 'name'|trans|capitalize }}</th>
                    <td>{{ user.name }}</td>
                </tr>
            </tbody>
        </table>
    </div>
    

    <a class="btn btn-outline-primary" href="{{ path('app_user_index') }}">{{ 'go back'|trans|capitalize }}</a>

    <a class="btn btn-outline-primary" href="{{ path('app_user_edit', {'id': user.id}) }}">{{ 'edit'|trans|capitalize }}</a>

    {{ include('user/_delete_form.html.twig') }}
{% endblock %}
