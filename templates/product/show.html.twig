{% extends 'base.html.twig' %}

{% block title %}{{ 'show product'|trans|capitalize }}{% endblock %}

{% block main %}
    <h1>{{product.name}}</h1>
    <div class="container">
        <div class="row">
            <figure class="figure col-3 text-center">
                <img class="figure-img" src="{{ asset('images/products/' ~ product.image) }}" alt="image {{ product.image }}">
                <figcaption>{{ product.name }}</figcaption>
            </figure>
            <div class="col-7">
                <p><strong>{{ 'description'|trans|capitalize }}:</strong></p>
                <p>{{ product.description }}</p>
                <p><strong>{{ 'price'|trans|capitalize }}: </strong>{{ product.price }}€</p>
                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                    <a class="btn btn-outline-success" href="{{ path('app_cart_add', {'id': product.id}) }}">{{ 'add to cart'|trans|capitalize }}</a>               
                {% else %}
                    <p class="error">* {{ 'add products to cart alert'|trans|capitalize }}</p>
                {% endif %}
            </div>            
        </div>
        <div class="row">
            <div class="col-3 text-center">
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-outline-primary" href="{{ path('app_product_index') }}">{{ 'go back'|trans|capitalize }}</a>
                    <a class="btn btn-outline-primary" href="{{ path('app_product_edit', {'id': product.id}) }}">{{ 'edit'|trans|capitalize }}</a>
                    {{ include('product/_delete_form.html.twig') }}
                {% else %}
                    <a class="btn btn-outline-success" href="{{ path('app_home') }}">{{ 'go back'|trans|capitalize }}</a>
                {% endif %}                
            </div>
        </div>
    </div>                
{% endblock %}
