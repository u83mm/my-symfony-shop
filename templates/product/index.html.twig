{% extends 'base.html.twig' %}

{% block title %}{{ 'product index'|trans|capitalize }}{% endblock %}

{% block main %}
    <h1>{{ 'product index'|trans|upper }}</h1>

    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead class="text-center">
                <tr>
                    <th>Id</th>
                    <th>{{ 'name'|trans|capitalize }}</th>
                    <th>{{ 'description'|trans|capitalize }}</th>
                    <th>{{ 'price'|trans|capitalize }}</th>
                    <th>{{ 'image'|trans|capitalize }}</th>
                    <th>{{ 'options'|trans|capitalize }}</th>
                </tr>
            </thead>
            <tbody>
            {% for product in products %}
                <tr class="align-middle">
                    <td>{{ product.id }}</td>
                    <td>{{ product.name }}</td>
                    <td><p>{{ product.description }}</p></td>
                    <td>{{ product.price }}€</td>
                    <td><img class="img-product-index" src="{{ asset('images/products/' ~ product.image) }}"></td>
                    <td class="options">
                        <a class="buttonLink" href="{{ path('app_product_show', {'id': product.id}) }}">{{ 'show'|trans|capitalize }}</a>
                        <a class="buttonLink" href="{{ path('app_product_edit', {'id': product.id}) }}">{{ 'edit'|trans|capitalize }}</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">no records found</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>    

    <a class="btn btn-outline-primary" href="{{ path('app_product_new') }}">{{ 'new product'|trans|capitalize }}</a>
{% endblock %}
